# ATProto JetStream Listener Configuration

# Mode: 'handle' to watch a specific user's repo, 'keyword' to watch for keywords
MODE=handle

# For handle mode: the Bluesky handle to watch
# Required when MODE=handle
HANDLE=username.bsky.social

# For handle mode (optional): the DID of the user
# If not provided, the handle will be resolved automatically
# DID=did:plc:...

# For keyword mode: comma-separated list of keywords to watch for in posts
# Required when MODE=keyword
# KEYWORDS=web development,typescript,javascript

# Subscriptions: which event types to subscribe to
# Options: 'posts', 'likes', or both ('posts,likes')
# Default: posts,likes
SUBSCRIPTIONS=posts,likes

# Actions to watch for
# Options: 'add', 'delete', or both ('add,delete')
# Default: add,delete
ACTIONS=add,delete

# Syslog configuration
# Host where syslog will receive events
SYSLOG_HOST=localhost

# Port for syslog (typically 514)
# Default: 514
SYSLOG_PORT=514

# Syslog facility (RFC 5424)
# Options: kernel, user, mail, daemon, auth, syslog, lpr, news, uucp, cron, local0-local7
# Numeric values 0-23 also accepted
# Default: local0
SYSLOG_FACILITY=local0

# Tag for syslog messages
# Default: atproto-listener
SYSLOG_TAG=atproto-listener

# starting point for the jetstream if you don't want to start at present. microseconds
# default: not set
JETSTREAM_CURSOR_START=1773453566000000

# if you want to store where you're at in the jetstream in case of restarts
JETSTREAM_CURSOR_CHECKPOINT_PATH=/cursor.json

# TAP backfill settings (only applies for handle MODE)
# When true, connect to a local TAP instance to backfill historical repo operations before consuming Jetstream live events
# TAP_BACKFILL=false
# TAP endpoint URL (WebSocket)
# TAP_BACKFILL_ENDPOINT=ws://localhost:2480/channel
# Optional: stop backfill when reaching events with createdAt >= this time (microseconds)
# TAP_BACKFILL_UNTIL=1773453566000000